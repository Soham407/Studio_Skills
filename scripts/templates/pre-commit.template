#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

# Studio-Grade pre-commit hook
# Runs: lint-staged → typecheck → Shannon-Pro security pointer

set -e

# 1. Lint & format staged files
echo "🧹 Running lint-staged..."
pnpm lint-staged

# 2. Type check (fast: only if tsc available)
if [ -f tsconfig.json ]; then
  echo "🔍 Type checking..."
  pnpm typecheck || {
    echo "❌ Type check failed. Fix errors before committing."
    exit 1
  }
fi

# 3. Shannon-Pro security pointer
if [ -f .claude/skills/business/shannon-security/SHANNON-PRO.md ]; then
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx)$' || true)
  if [ -n "$STAGED_FILES" ]; then
    echo "🛡️  Shannon-Pro: Security audit available at .claude/skills/business/shannon-security/"
    echo "    For sensitive changes, ask Claude: 'audit my staged changes using Shannon-Pro'"
  fi
fi

echo "✅ Pre-commit checks passed"
