{
  "name": "@studio-skills/kickstart",
  "version": "1.0.0",
  "description": "Studio-Grade project bootstrapper with cross-agent skills",
  "bin": {
    "kickstart": "./bin/kickstart.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "skills:lint": "node scripts/lint-skills.js",
    "skills:catalog": "node scripts/generate-skills-catalog.js",
    "check": "npm run skills:lint && npm test && npm pack --dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Soham407/Studio_Skills.git"
  },
  "homepage": "https://github.com/Soham407/Studio_Skills#readme",
  "bugs": {
    "url": "https://github.com/Soham407/Studio_Skills/issues"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "gemini-cli",
    "skills",
    "local-models",
    "bootstrap",
    "cli",
    "nextjs",
    "expo"
  ],
  "files": [
    "bin/",
    "lib/",
    "skills.json",
    "README.md",
    "ARCHITECTURE.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE"
  ],
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.6.0"
